#!/usr/bin/env bash
# Install (or reinstall) the trading-agent LaunchAgents.
# Idempotent: safe to re-run after editing plists.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TARGET_DIR="$HOME/Library/LaunchAgents"
mkdir -p "$TARGET_DIR" "$REPO_DIR/logs"

for label in com.jasonli.trading-agent com.jasonli.trading-watchdog com.jasonli.trading-extension-forwarder; do
    src="$REPO_DIR/infra/launchd/${label}.plist"
    dst="$TARGET_DIR/${label}.plist"
    if launchctl list "$label" >/dev/null 2>&1; then
        launchctl unload "$dst" 2>/dev/null || true
    fi
    cp "$src" "$dst"
    launchctl load "$dst"
    echo "loaded $label"
done

echo
echo "Agents loaded (RunAtLoad=false). Use bin/agent-start to launch."
