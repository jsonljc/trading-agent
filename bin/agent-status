#!/usr/bin/env bash
# Show whether the bridge and agent are running, plus tail of their logs.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

show() {
    local label="$1"
    local row
    row="$(launchctl list | awk -v l="$label" '$3==l {print}')"
    if [ -z "$row" ]; then
        echo "  $label: NOT LOADED (run bin/agent-install)"
        return
    fi
    local pid status
    pid="$(echo "$row" | awk '{print $1}')"
    status="$(echo "$row" | awk '{print $2}')"
    if [ "$pid" = "-" ]; then
        echo "  $label: stopped (last exit=$status)"
    else
        echo "  $label: running pid=$pid"
    fi
}

echo "Status:"
show com.jasonli.trading-bridge
show com.jasonli.trading-agent
show com.jasonli.trading-watchdog

if [ -S /tmp/trading_bridge.sock ]; then
    echo "  socket /tmp/trading_bridge.sock: present"
else
    echo "  socket /tmp/trading_bridge.sock: ABSENT"
fi

echo
echo "Last 5 agent log lines:"
tail -n 5 "$REPO_DIR/logs/agent.log" 2>/dev/null | sed 's/^/  /' || echo "  (no log)"
