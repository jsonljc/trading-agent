#!/usr/bin/env bash
# Show whether the bridge and agent are running, plus tail of their logs.
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"

show() {
    local label="$1"
    local row
    row="$(launchctl list | awk -v l="$label" '$3==l {print}')"
    if [ -z "$row" ]; then
        echo "  $label: NOT LOADED (run bin/agent-install)"
        return
    fi
    local pid status
    pid="$(echo "$row" | awk '{print $1}')"
    status="$(echo "$row" | awk '{print $2}')"
    if [ "$pid" = "-" ]; then
        echo "  $label: stopped (last exit=$status)"
    else
        echo "  $label: running pid=$pid"
    fi
}

echo "Status:"
show com.jasonli.trading-agent
show com.jasonli.trading-bridge
show com.jasonli.trading-extension-forwarder
show com.jasonli.trading-watchdog

if [ -S /tmp/trading_bridge.sock ]; then
    echo "  socket /tmp/trading_bridge.sock: present"
else
    echo "  socket /tmp/trading_bridge.sock: ABSENT"
fi

# Probe for active macOS Focus / DND. Active focus silences notifications,
# which means Discord banners never reach the notification DB and the bridge
# captures nothing.
FOCUS_PROBE="$REPO_DIR/.venv/bin/python"
if [ -x "$FOCUS_PROBE" ]; then
    active_focus=$("$FOCUS_PROBE" - <<'EOF' 2>/dev/null
import json, pathlib
p = pathlib.Path.home() / "Library/DoNotDisturb/DB/Assertions.json"
try:
    data = json.loads(p.read_text())
except Exception:
    print("")
    raise SystemExit
for entry in data.get("data", []):
    invalidated = {x.get("invalidationAssertion", {}).get("assertionUUID")
                   for x in entry.get("storeInvalidationRecords", [])}
    for r in entry.get("storeAssertionRecords", []):
        if r.get("assertionUUID") not in invalidated:
            mode = r.get("assertionDetails", {}).get("assertionDetailsModeIdentifier", "?")
            print(mode)
            raise SystemExit
EOF
)
    if [ -n "$active_focus" ]; then
        echo
        echo "  ⚠️  Focus mode ACTIVE: $active_focus"
        echo "     macOS suppresses notifications while Focus is on — Discord banners will not"
        echo "     reach the notification DB and the bridge will capture nothing."
        echo "     Turn off Focus via the menu bar Control Center → Focus tile."
    fi
fi

if [ ! -f "$REPO_DIR/data/.market_data_subscribed" ]; then
    echo
    echo "  ⚠️  IB market data subscriptions NOT marked active."
    echo "     Real signals will likely fail at OrderSizer (no valid price)."
    echo "     Subscribe in IB Client Portal, then:  touch data/.market_data_subscribed"
fi

echo
echo "Last 5 agent log lines:"
tail -n 5 "$REPO_DIR/logs/agent.log" 2>/dev/null | sed 's/^/  /' || echo "  (no log)"
